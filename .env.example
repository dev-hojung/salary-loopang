# Supabase 연결 정보 — 실제 값은 .env.local 에 넣으세요(커밋 금지).
# Supabase Dashboard → Project Settings → API 에서 확인.

# 브라우저·서버 공용 (anon). NEXT_PUBLIC_ 접두사라 클라이언트로 노출됨.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# 서버 전용 (service role). 절대 NEXT_PUBLIC_ 붙이지 말 것 — API 라우트에서만 사용.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# (선택) 서비스 공개 URL — SEO 의 canonical/Open Graph/sitemap/robots 에 사용.
# 미설정 시: Railway 자동 도메인(RAILWAY_PUBLIC_DOMAIN) → http://localhost:3000 순으로 폴백.
# 커스텀 도메인이 확정되면 설정 권장. 예: https://ddanjit.app
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
